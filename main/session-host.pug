doctype html
html
  head
    title Waiting Session - Host
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="/css/session-host.css")
    script(src="https://cdn.jsdelivr.net/npm/qrcode@1.4.4/build/qrcode.min.js")
  body
    .host-wrapper
      .host-container
        .header-section
          .title-group
            h1 Game Session Code :
          
          .qr-group
            .code-pill Code
            .qr-box
              canvas#qrCanvas
            .room-code-text= roomCode

        .players-grid#playersGrid
          each val in [1, 2, 3, 4, 5, 6]
            .player-slot(id=`slot-${val}`)
              span.waiting-text Waiting...

        .footer-section
          button#exitBtn.btn-pill-exit EXIT
          .host-id-group
            span Host ID: 
            span.id-display= room.host_user_id
          button#startBtn.btn-pill-start START

    script.
      const SESSION_ID = "#{room.session_id}";
      const ROOM_CODE = "#{roomCode}";
    script(src="/js/session-host.js")